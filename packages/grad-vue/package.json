{
    "name": "@illinois-grad/grad-vue",
    "version": "1.0.0",
    "description": "Shared Vue.js components for Graduate College apps.",
    "keywords": [
        "vue",
        "vue3",
        "components",
        "graduate-college"
    ],
    "author": "University of Illinois Graduate College",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/graduatecollege/grad-vue.git"
    },
    "type": "module",
    "main": "./dist/grad-vue.js",
    "module": "./dist/grad-vue.js",
    "exports": {
        ".": {
            "import": "./dist/grad-vue.js"
        },
        "./plugin": {
            "import": "./dist/plugin.js"
        },
        "./web-components": {
            "import": "./dist/grad-vue-elements.js"
        },
        "./web-components.css": {
            "import": "./dist/grad-vue-elements.css"
        },
        "./grad-vue.css": {
            "import": "./dist/grad-vue.css"
        },
        "./custom-elements": {
            "types": "./dist/custom-elements.d.ts"
        }
    },
    "customElements": "custom-elements.json",
    "files": [
        "dist",
        "custom-elements.json"
    ],
    "scripts": {
        "build": "node --experimental-strip-types ../../scripts/generate-custom-element-types.ts && vite build && vite build --config vite.web-components.config.ts && vue-tsc --emitDeclarationOnly",
        "build:elements": "vite build --config vite.web-components.config.ts"
    },
    "dependencies": {
        "@vueuse/core": "^14",
        "@vueuse/integrations": "^14",
        "focus-trap": "^7",
        "vue": "^3.5"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.4",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4",
        "vue-tsc": "^3.2.5"
    }
}
